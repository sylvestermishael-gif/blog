rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return (
        (!data.has('displayName') || data.displayName == null || data.displayName is string) &&
        (!data.has('email') || data.email == null || data.email is string) &&
        (!data.has('createdAt') || data.createdAt is timestamp)
      );
    }

    // --- Matches ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId);
    }

    match /follows/{followId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.followerId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    match /test/{connId} {
      allow read: if true;
    }
  }
}
